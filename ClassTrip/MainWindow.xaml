<Window x:Class="ClassTrip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClassTrip"
        xmlns:vm="clr-namespace:ClassTrip.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="auto" Width="900">
    <Window.DataContext>
        <vm:ClassTripViewModel/>
    </Window.DataContext>
    <Grid>
        <StackPanel Margin="10">
            <Label HorizontalAlignment="Center">Osztály Kirándulás</Label>
            <Label>Az összes befizetett összeget</Label>
            <TextBlock Text="{Binding SumDeposit}"></TextBlock>
            <Label>Az átlagos befizetett összeget</Label>
            <TextBlock Text="{Binding AvgDeposit}"></TextBlock>
            <Label>A legnagyobb befizetést</Label>
            <TextBlock Text="{Binding MaxDeposit}"></TextBlock>
            <Label>Azoknak a tanulóknak a számát, akik még nem fizettek be semmit</Label>
            <TextBlock Text="{Binding NoPaidAmountCount}"></TextBlock>

            <ListView  ItemsSource="{Binding Datas}" SelectedItem="{Binding SelectedItem}" Height="250">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Id" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Class" DisplayMemberBinding="{Binding Class}"/>
                        <GridViewColumn Header="Destination" DisplayMemberBinding="{Binding Destination}"/>
                        <GridViewColumn Header="PaidAmount" DisplayMemberBinding="{Binding PaidAmount}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label>Módosítás</Label>
                    <Label>Diák Neve:</Label>
                    <TextBlock Text="{Binding SelectedItem.Name}"></TextBlock>
                    <Label>Befizetett Összeg</Label>
                    <TextBox Text="{Binding ChangePaidAmount , UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    <Button Content="Módosítás" Command="{Binding UpdateDataCommand}"></Button>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Label>Új Létrehozás</Label>
                    <Label>Új Név</Label>
                    <TextBox Text="{Binding NewName , UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    <Label>Új Osztály</Label>
                    <TextBox Text="{Binding NewClass , UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    <Label>Új Hely</Label>
                    <TextBox Text="{Binding NewDestination, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    <Label>Új Befizetési Összeg</Label>
                    <TextBox Text="{Binding NewPaidAmount, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    <Button Content="Létrehozás" Command="{Binding CreateDataCommand}"></Button>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Label>Kitörlés</Label>
                    <Label>Diák Neve:</Label>
                    <TextBlock Text="{Binding SelectedItem.Name}"></TextBlock>
                    <Button Content="Törlés" Command="{Binding DeleteDataCommand}"></Button>
                </StackPanel>
            
            </Grid>
            
        </StackPanel>
    </Grid>
</Window>
